    LANGUAGE "plpgsql"
    AS $$
BEGIN
  -- BYPASS universal para migraciones controladas
  IF public.app_admin_mode() THEN
    RETURN NEW;
  END IF;
  if tg_op = 'INSERT' then
    if new.org_id is null then
      new.org_id := app.current_org_id();
