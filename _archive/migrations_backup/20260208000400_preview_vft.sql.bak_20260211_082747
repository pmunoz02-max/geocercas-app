    LANGUAGE "plpgsql"
    AS $$
declare
  v_role_text text;
begin
  -- Convertir enum -> text para validaciones
  v_role_text := btrim(coalesce(new.role::text, ''));

  if v_role_text = '' then
    raise exception 'memberships.role no puede ser vacío';
  end if;

  -- Validar que el valor exista en el enum role_type
  if not exists (
    select 1
    from pg_enum e
