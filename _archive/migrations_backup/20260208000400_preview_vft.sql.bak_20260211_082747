  ) then
    execute 'delete from public.user_geofence_state where user_id = $1::text'
      using p_user_id::text;
  end if;

  ----------------------------------------------------------------
  -- 4) Profiles / logs
  ----------------------------------------------------------------

  if exists (
    select 1 from information_schema.columns
    where table_schema = 'public'
      and table_name   = 'profiles'
      and column_name  = 'id'
  ) then
