        CASE
            WHEN ("geom" IS NULL) THEN NULL::"jsonb"
            WHEN ("public"."geometrytype"("geom") = ANY (ARRAY['POLYGON'::"text", 'MULTIPOLYGON'::"text"])) THEN ("public"."st_asgeojson"("public"."st_transform"("geom", 4326)))::"jsonb"
