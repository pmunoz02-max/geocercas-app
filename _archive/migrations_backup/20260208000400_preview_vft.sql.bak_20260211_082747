CREATE OR REPLACE FUNCTION "public"."_resolve_tenant_for_current_user"() RETURNS "uuid"
    LANGUAGE "plpgsql" SECURITY DEFINER
    SET "search_path" TO 'public'
AS $$
declare
  v_org_id uuid;
  v_role text;
  v_prev_row_security text;
begin
  -- Guardar estado previo y desactivar RLS solo dentro de esta función
  v_prev_row_security := current_setting('row_security', true);
  perform set_config('row_security','off', true);

  select b.org_id, b.role
    into v_org_id, v_role
  from public.bootstrap_session_context() b
  limit 1;

  -- Bootstrap-safe: en migraciones / sesiones sin contexto no debe romper
  if v_org_id is null then
    -- Restaurar row_security al estado previo (si existía)
    if v_prev_row_security is not null then
      perform set_config('row_security', v_prev_row_security, true);
    end if;
    return null;
  end if;

  perform set_config('app.tenant_id', v_org_id::text, true);

  -- Restaurar row_security al estado previo (si existía)
  if v_prev_row_security is not null then
    perform set_config('row_security', v_prev_row_security, true);
  end if;

  return v_org_id;
end;
$$;

ALTER FUNCTION "public"."_resolve_tenant_for_current_user"() OWNER TO "postgres";

