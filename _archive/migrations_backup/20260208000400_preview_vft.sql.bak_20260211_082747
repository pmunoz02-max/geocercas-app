    where t.typname = 'role_type'
      and e.enumlabel = v_role_text
  ) then
    raise exception 'Rol inválido para memberships.role: %', v_role_text;
  end if;

  -- Reasignar correctamente como enum
  new.role := v_role_text::public.role_type;

  return new;
end;
