    LANGUAGE "sql"
    AS $$
  WITH t AS (
    SELECT COALESCE(
      _tenant_id,
      (SELECT u.tenant_id FROM public.users_public u WHERE u.id = auth.uid())
    ) AS tenant_id_res
  )
