{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.tugeocercas.com"
        }
      ],
      "destination": "https://tugeocercas.com/$1",
      "permanent": true
    },

    {
      "source": "/",
      "has": [
        { "type": "query", "key": "code", "value": "(.*)" },
        { "type": "query", "key": "next", "value": "(.*)" }
      ],
      "destination": "/auth/callback?code=$1&next=$2",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "code", "value": "(.*)" }
      ],
      "destination": "/auth/callback?code=$1",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
