{
  "version": 2,

  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],

  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "^(.*)$", "dest": "/index.html" }
  ],

  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.tugeocercas.com" }],
      "destination": "https://tugeocercas.com/$1",
      "permanent": true
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "preview.tugeocercas.com" }],
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    }
  ]
}