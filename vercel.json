{
  "version": 2,
  "routes": [
    { "src": "/api/auth/(.*)", "dest": "/api/auth?route=$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },

    { "src": "/demo/mwea", "dest": "/demo/mwea-geofence-demo.html" },
    { "src": "/demo/quito", "dest": "/demo/quito-geofence-demo.html" },

    { "handle": "filesystem" },

    { "src": "/(.*)", "dest": "/" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon\\.ico|robots\\.txt|sitemap\\.xml)$",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}