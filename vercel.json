{
  "version": 2,
  "rewrites": [
    {
      "source": "/tracker-accept",
      "destination": "/tracker-gps"
    },
    {
      "source": "/tracker-accept/:path*",
      "destination": "/tracker-gps"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth?route=:path*"
    },
    {
      "source": "/((?!api/|assets/|favicon\\.ico$|robots\\.txt$|sitemap\\.xml$|manifest\\.webmanifest$|site\\.webmanifest$|service-worker\\.js$|sw\\.js$|workbox-).*?)$",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/$",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/(.*)\\.html$",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/(service-worker\\.js|sw\\.js)$",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}