{
  "version": 2,
  "routes": [
    { "src": "/mwea-geofence-demo.html", "dest": "/mwea-geofence-demo.html" },
    { "src": "/quito-geofence-demo.html", "dest": "/quito-geofence-demo.html" },

    { "src": "/tracker-accept", "dest": "/tracker-gps" },
    { "src": "/tracker-accept/(.*)", "dest": "/tracker-gps" },

    { "src": "/api/auth/(.*)", "dest": "/api/auth?route=$1" },

    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },

    { "src": "/(.*)", "dest": "/" }
  ]
}