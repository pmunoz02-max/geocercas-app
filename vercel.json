{
  "version": 2,
  "rewrites": [
    { "source": "/tracker-accept", "destination": "/tracker-gps" },
    { "source": "/tracker-accept/(.*)", "destination": "/tracker-gps" },

    { "source": "/api/auth/(.*)", "destination": "/api/auth?route=$1" },

    { "source": "/demo/mwea", "destination": "/demo/mwea-geofence-demo.html" },
    { "source": "/demo/quito", "destination": "/demo/quito-geofence-demo.html" },

    {
      "source": "/((?!api/|assets/|demo/.*\\.html$|favicon\\.ico$|robots\\.txt$|sitemap\\.xml$|manifest\\.webmanifest$|site\\.webmanifest$|service-worker\\.js$|sw\\.js$|workbox-).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon\\.ico|robots\\.txt|sitemap\\.xml|manifest\\.webmanifest|site\\.webmanifest)$",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    },
    {
      "source": "/(service-worker\\.js|sw\\.js|workbox-.*\\.js)$",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    }
  ]
}