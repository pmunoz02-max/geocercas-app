{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node@3.2.25" },
    { "src": "api/**/*.cjs", "use": "@vercel/node@3.2.25" },
    { "src": "package.json", "use": "@vercel/static-build@2.7.3" }
  ],
  "rewrites": [
    {
      "source": "/tracker-accept",
      "destination": "/tracker-gps"
    },
    {
      "source": "/tracker-accept/:path*",
      "destination": "/tracker-gps"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth?route=:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}