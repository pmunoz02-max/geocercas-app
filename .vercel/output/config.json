{
  "version": 3,
  "routes": [
    {
      "src": "^(?:/(.*))$",
      "headers": {
        "Location": "https://tugeocercas.com/$1"
      },
      "status": 308,
      "has": [
        {
          "type": "host",
          "value": "www.tugeocercas.com"
        }
      ]
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(?:/(.*))$",
      "dest": "/index.html",
      "check": true
    },
    {
      "src": "^/api(/.*)?$",
      "status": 404
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    },
    {
      "handle": "miss"
    },
    {
      "src": "^/api/(.+)(?:\\.(?:ts|js))$",
      "dest": "/api/$1",
      "check": true
    }
  ],
  "framework": {
    "version": "5.4.21"
  },
  "crons": []
}
