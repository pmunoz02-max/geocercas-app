#!/bin/sh

# Optional docs override policy.
# If docs/ files are staged, require [allow-docs] in the commit message.

set -eu

MSG_FILE="$1"
STAGED_DOCS="$(git diff --cached --name-only --diff-filter=ACMR -- docs/)"

if [ -n "$STAGED_DOCS" ]; then
	if grep -q '\[allow-docs\]' "$MSG_FILE"; then
		exit 0
	fi

	echo ""
	echo "ERROR: Commit message missing required override tag for docs/ changes."
	echo ""
	echo "Staged docs files:"
	echo "$STAGED_DOCS"
	echo ""
	echo "To proceed, add [allow-docs] to the commit message."
	echo ""
	exit 1
fi
